<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="jdm.fx.PatientController">
    <top>
        <VBox spacing="6">
            <padding><Insets top="14" right="16" bottom="8" left="16"/></padding>
            <Label fx:id="welcomeLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <HBox spacing="10">
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Logout" onAction="#logout"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <padding><Insets top="4" right="12" bottom="12" left="12"/></padding>
            <Tab text="My dossier">
                <TextArea fx:id="dossierArea" editable="false" wrapText="true"/>
            </Tab>
            <Tab text="Laboratory (read-only)">
                <TableView fx:id="labTable"/>
            </Tab>
            <Tab text="CMAS">
                <VBox spacing="6">
                    <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                    <VBox fx:id="chartBox"/>
                    <TableView fx:id="cmasTable" VBox.vgrow="ALWAYS"/>
                </VBox>
            </Tab>
            <Tab text="Appointments">
                <VBox spacing="8">
                    <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                    <TableView fx:id="apptTable" VBox.vgrow="ALWAYS"/>
                    <HBox spacing="8">
                        <DatePicker fx:id="apDate"/>
                        <TextField fx:id="apTime" promptText="H:mm" prefWidth="80"/>
                        <TextField fx:id="apReason" promptText="reason" prefWidth="240"/>
                        <Button text="Request appointment" onAction="#scheduleOwn"/>
                    </HBox>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
