<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="jdm.fx.DoctorController">
    <top>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Label text="JDM — Doctor dashboard" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#logout"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="10">
            <padding><Insets top="8" right="16" bottom="16" left="16"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Patient"/>
                <ComboBox fx:id="patientCombo" prefWidth="440"/>
                <Button text="Refresh list" onAction="#refreshPatientList"/>
                <Button text="Export dossier…" onAction="#exportDossier"/>
            </HBox>
            <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                <Tab text="Summary">
                    <TextArea fx:id="summaryArea" editable="false" wrapText="true"/>
                </Tab>
                <Tab text="Laboratory">
                    <VBox spacing="8">
                        <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                        <HBox spacing="8">
                            <Button text="New lab line" onAction="#addNewLabResult"/>
                            <Button text="Delete selected lab" onAction="#deleteSelectedLab"/>
                        </HBox>
                        <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS">
                            <TableView fx:id="labTable"/>
                            <VBox spacing="6">
                                <Label text="Measurements for selected lab"/>
                                <TableView fx:id="measurementTable" VBox.vgrow="ALWAYS"/>
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="Add measurement"/>
                                    <DatePicker fx:id="measDate"/>
                                    <TextField fx:id="measValue" promptText="value" prefWidth="120"/>
                                    <Button text="Add" onAction="#addMeasurement"/>
                                    <Button text="Edit selected measurement" onAction="#editSelectedMeasurement"/>
                                    <Button text="Delete selected measurement" onAction="#deleteSelectedMeasurement"/>
                                </HBox>
                                <TextArea fx:id="measurementHint" editable="false" prefRowCount="4" wrapText="true"/>
                            </VBox>
                        </SplitPane>
                    </VBox>
                </Tab>
                <Tab text="CMAS">
                    <VBox spacing="6">
                        <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                        <VBox fx:id="cmasChartParent" spacing="4"/>
                        <Label text="All CMAS grid rows"/>
                        <TableView fx:id="cmasTable" prefHeight="220" VBox.vgrow="SOMETIMES"/>
                    </VBox>
                </Tab>
                <Tab text="Appointments">
                    <VBox spacing="8">
                        <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                        <TableView fx:id="appointmentTable" VBox.vgrow="ALWAYS"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Schedule"/>
                            <DatePicker fx:id="apDate"/>
                            <TextField fx:id="apTime" promptText="H:mm" prefWidth="80"/>
                            <TextField fx:id="apReason" promptText="reason" prefWidth="220"/>
                            <Button text="Schedule" onAction="#scheduleAppointment"/>
                        </HBox>
                    </VBox>
                </Tab>
                <Tab text="Analytics">
                    <VBox spacing="8">
                        <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                        <HBox spacing="8">
                            <Label text="Biomarker"/>
                            <ComboBox fx:id="biomarkerCombo" prefWidth="140"/>
                            <Button text="Run same-day correlation" onAction="#runCorrelation"/>
                        </HBox>
                        <TextArea fx:id="analyticsArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>
                    </VBox>
                </Tab>
            </TabPane>
        </VBox>
    </center>
</BorderPane>
