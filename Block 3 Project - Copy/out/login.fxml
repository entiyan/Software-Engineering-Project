<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="jdm.fx.LoginController">
      
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="JDM Healthcare Data" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
    <Label text="Doctors: username. Patients: paste patient UUID." style="-fx-font-size: 11px; -fx-text-fill: gray;"/>
    <TextField fx:id="username" promptText="Username or patient UUID"/>
    <PasswordField fx:id="password" promptText="Password"/>
    <Button text="Login" onAction="#handleLogin" prefWidth="100"/>
    <Label fx:id="message" textFill="red" />
</VBox>